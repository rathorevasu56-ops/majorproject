</head>
<body>
    <!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Unsplash Image</title>

  <style>
    body {
      font-family: Arial;
      text-align: center;
      background: #f5f5f5;
      padding: 30px;
    }

    .card {
      background: white;
      padding: 20px;
      width: 60%;
      margin: auto;
      border-radius: 10px;
      box-shadow: 0 0 10px rgba(0,0,0,0.2);
    }

    img {
      width: 100%;
      border-radius: 10px;
    }

    h2 {
      color: #333;
    }
  </style>

</head>
<body>

  <div class="card">
    <h2>Fetched Image from Unsplash</h2>

    <img src="<%= img.url %>" alt="Unsplash Image">

    <p>Filename: <%= img.filename %></p>
  </div>

</body>
</html>
</body>
<script src="fetchimage.js"></script>
</html>